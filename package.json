{
  "name": "catalou-web-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "pnpm run build && wrangler dev",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "generate:auth": "openapi-typescript ${CONTRACTS_PATH:-../catalou-platform-core/contracts/openapi}/auth.yaml -o src/generated/auth.ts",
    "generate:catalog": "openapi-typescript ${CONTRACTS_PATH:-../catalou-platform-core/contracts/openapi}/catalog.yaml -o src/generated/catalog.ts",
    "generate": "pnpm generate:auth && pnpm generate:catalog",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0",
  "dependencies": {
    "autoprefixer": "^10.5.0",
    "framer-motion": "^12.40.0",
    "i18next": "^26.0.8",
    "idb": "^8.0.3",
    "postcss": "^8.5.14",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.6",
    "react-router-dom": "^7.15.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.39.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1",
    "wrangler": "^4.97.0"
  }
}
