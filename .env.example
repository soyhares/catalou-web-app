# ─── API ──────────────────────────────────────────────────────────────────────

# Base URL for catalou-core-api (no trailing slash)
# Development: http://localhost:3000
# Production: Railway-generated URL (e.g., https://catalou-core-api.up.railway.app)
VITE_API_URL=http://localhost:3000

# ─── Supabase (Auth only) ─────────────────────────────────────────────────────

# From: Supabase dashboard → Project Settings → API
# These are safe to expose on the frontend (anon key only — never service_role)
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# ─── PWA / Subdomain Resolution ───────────────────────────────────────────────

# The root domain used to extract the company slug from the subdomain.
# Production: catalou.com
# Development: localhost (slug resolution is disabled in dev; use VITE_DEV_SLUG instead)
VITE_CATALOU_DOMAIN=catalou.com

# Development only: hardcoded company slug for local testing (bypasses subdomain resolution)
# Leave empty in production.
VITE_DEV_SLUG=
